import React, { useState, useEffect, useCallback } from 'react';
import { 
  Trophy, Star, Volume2, ArrowRight, ArrowLeft, 
  RotateCcw, Award, CheckCircle, XCircle, 
  BookOpen, Languages, Headphones, Timer, 
  Layout, HelpCircle, GraduationCap, Play
} from 'lucide-react';

// --- إعدادات مفتاح API ---
const apiKey = ""; 

// --- بيانات المحاكاة (مجموعة كاملة من 18 سؤالاً) ---
const EXAM_DATA = {
  reading: [
    { id: 1, type: 'img', text: 'Find the "Sun"', options: [{id:'a', val:'☀️'}, {id:'b', val:'☁️'}, {id:'c', val:'🌙'}], correct: 'a' },
    { id: 2, type: 'text', text: 'The boy is ...', options: [{id:'a', val:'Running'}, {id:'b', val:'Eating'}, {id:'c', val:'Sleeping'}], correct: 'a' },
    { id: 3, type: 'img', text: 'Which is a "Dog"?', options: [{id:'a', val:'🐱'}, {id:'b', val:'🐶'}, {id:'c', val:'🐹'}], correct: 'b' },
    { id: 4, type: 'text', text: 'An orange is ...', options: [{id:'a', val:'Blue'}, {id:'b', val:'Orange'}, {id:'c', val:'Pink'}], correct: 'b' },
    { id: 5, type: 'text', text: 'I have two ...', options: [{id:'a', val:'Eyes'}, {id:'b', val:'Nose'}, {id:'c', val:'Mouth'}], correct: 'a' },
    { id: 6, type: 'img', text: 'Show me the "Tree"', options: [{id:'a', val:'🌳'}, {id:'b', val:'🏠'}, {id:'c', val:'🚗'}], correct: 'a' },
  ],
  useOfLanguage: [
    { id: 7, text: 'Hello, what ___ your name?', options: [{id:'a', val:'is'}, {id:'b', val:'am'}, {id:'c', val:'are'}], correct: 'a' },
    { id: 8, text: 'She ___ a red dress.', options: [{id:'a', val:'has'}, {id:'b', val:'have'}, {id:'c', val:'is'}], correct: 'a' },
    { id: 9, text: 'The birds are ___ the sky.', options: [{id:'a', val:'on'}, {id:'b', val:'in'}, {id:'c', val:'under'}], correct: 'b' },
    { id: 10, text: 'These are my ___ .', options: [{id:'a', val:'friend'}, {id:'b', val:'friends'}, {id:'c', val:'friending'}], correct: 'b' },
    { id: 11, text: '___ you like milk?', options: [{id:'a', val:'Do'}, {id:'b', val:'Does'}, {id:'c', val:'Is'}], correct: 'a' },
    { id: 12, text: 'I can ___ a bike.', options: [{id:'a', val:'ride'}, {id:'b', val:'rides'}, {id:'c', val:'riding'}], correct: 'a' },
  ],
  listening: [
    { id: 13, audio: 'Listen and find the red apple.', options: [{id:'a', val:'🍎', color: 'red'}, {id:'b', val:'🍏', color: 'green'}, {id:'c', val:'🍌', color: 'yellow'}], correct: 'a' },
    { id: 14, audio: 'How many stars? Listen: One, two, three, four.', options: [{id:'a', val:'3'}, {id:'b', val:'4'}, {id:'c', val:'5'}], correct: 'b' },
    { id: 15, audio: 'The cat says Meow. Point to the cat.', options: [{id:'a', val:'🐶'}, {id:'b', val:'🐱'}, {id:'c', val:'🐭'}], correct: 'b' },
    { id: 16, audio: 'Find the big bus.', options: [{id:'a', val:'🚌', size: 'small'}, {id:'b', val:'🚕', size: 'big'}, {id:'c', val:'🚌', size: 'large'}], correct: 'c' },
    { id: 17, audio: 'Touch the blue balloon.', options: [{id:'a', val:'🎈', color: 'blue'}, {id:'b', val:'🎈', color: 'red'}, {id:'c', val:'🎈', color: 'yellow'}], correct: 'a' },
    { id: 18, audio: 'Listen: Goodbye! Who is waving?', options: [{id:'a', val:'🙋‍♂️'}, {id:'b', val:'😴'}, {id:'c', val:'🍔'}], correct: 'a' },
  ]
};

const SECTIONS = [
  { key: 'reading', label: 'القراءة', icon: BookOpen, color: 'text-blue-600', bg: 'bg-blue-50' },
  { key: 'useOfLanguage', label: 'اللغة', icon: Languages, color: 'text-pink-600', bg: 'bg-pink-50' },
  { key: 'listening', label: 'الاستماع', icon: Headphones, color: 'text-orange-600', bg: 'bg-orange-50' }
];

export default function App() {
  const [gameState, setGameState] = useState('lobby'); // lobby, testing, review, results
  const [currentSectionIdx, setCurrentSectionIdx] = useState(0);
  const [currentQuestionIdx, setCurrentQuestionIdx] = useState(0);
  const [userAnswers, setUserAnswers] = useState({});
  const [timer, setTimer] = useState(1200); // 20 دقيقة بالثواني
  const [isAudioPlaying, setIsAudioPlaying] = useState(false);

  const currentSectionKey = SECTIONS[currentSectionIdx].key;
  const questions = EXAM_DATA[currentSectionKey];
  const currentQuestion = questions[currentQuestionIdx];

  // --- وظائف المنطق ---
  const startExam = () => {
    setGameState('testing');
    setUserAnswers({});
    setCurrentSectionIdx(0);
    setCurrentQuestionIdx(0);
    setTimer(1200);
  };

  useEffect(() => {
    let interval;
    if (gameState === 'testing' && timer > 0) {
      interval = setInterval(() => setTimer(t => t - 1), 1000);
    } else if (timer === 0 && gameState === 'testing') {
      setGameState('results');
    }
    return () => clearInterval(interval);
  }, [gameState, timer]);

  const handleAnswer = (optionId) => {
    setUserAnswers(prev => ({
      ...prev,
      [currentQuestion.id]: optionId
    }));

    // تأخير بسيط للانتقال للسؤال التالي
    setTimeout(() => {
      if (currentQuestionIdx < questions.length - 1) {
        setCurrentQuestionIdx(currentQuestionIdx + 1);
      } else if (currentSectionIdx < SECTIONS.length - 1) {
        setCurrentSectionIdx(currentSectionIdx + 1);
        setCurrentQuestionIdx(0);
      } else {
        setGameState('results');
      }
    }, 400);
  };

  const playTTS = async (text) => {
    if (isAudioPlaying) return;
    setIsAudioPlaying(true);
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: `Say slowly and clearly for a small child: ${text}` }] }],
          generationConfig: {
            responseModalities: ["AUDIO"],
            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Puck" } } }
          },
          model: "gemini-2.5-flash-preview-tts"
        })
      });
      const result = await response.json();
      const audioData = result.candidates[0].content.parts[0].inlineData;
      const binaryString = atob(audioData.data);
      const bytes = new Uint8Array(binaryString.length);
      for (let i = 0; i < binaryString.length; i++) bytes[i] = binaryString.charCodeAt(i);
      
      const wavHeader = new Uint8Array([82,73,70,70,0,0,0,0,87,65,86,69,102,109,116,32,16,0,0,0,1,0,1,0,128,187,0,0,0,119,1,0,2,0,16,0,100,97,116,97,0,0,0,0]);
      const blob = new Blob([wavHeader, bytes], { type: 'audio/wav' });
      const audio = new Audio(URL.createObjectURL(blob));
      audio.onended = () => setIsAudioPlaying(false);
      audio.play();
    } catch (e) {
      setIsAudioPlaying(false);
      console.error("Audio failed", e);
    }
  };

  const calculateScore = () => {
    let correct = 0;
    Object.values(EXAM_DATA).flat().forEach(q => {
      if (userAnswers[q.id] === q.correct) correct++;
    });
    return correct;
  };

  const formatTime = (s) => `${Math.floor(s / 60)}:${(s % 60).toString().padStart(2, '0')}`;

  // --- مكونات واجهة المستخدم ---
  const Lobby = () => (
    <div className="flex flex-col items-center max-w-4xl mx-auto py-10 px-4 text-center">
      <div className="bg-white p-12 rounded-[3rem] shadow-2xl border-b-8 border-blue-200 relative overflow-hidden w-full">
        <div className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-blue-400 via-pink-400 to-orange-400"></div>
        <GraduationCap className="w-24 h-24 text-blue-500 mx-auto mb-6 drop-shadow-sm" />
        <h1 className="text-5xl font-black text-gray-800 mb-4 tracking-tight">Baby Hippo <span className="text-blue-600">Olympiad</span></h1>
        <p className="text-xl text-gray-500 mb-10 max-w-lg mx-auto leading-relaxed">
          أهلاً بك في منصة المحاكاة الكاملة لأولمبياد هيبو العالمي. استعد لتجربة اختبار حقيقية تجمع بين المتعة والتعلم.
        </p>
        
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
          {SECTIONS.map(s => {
            const IconComponent = s.icon;
            return (
              <div key={s.key} className={`${s.bg} p-6 rounded-3xl border-2 border-white shadow-sm flex flex-col items-center group transition-transform hover:scale-105`}>
                <IconComponent className={`w-10 h-10 ${s.color} mb-3`} />
                <span className="font-bold text-gray-700">{s.label}</span>
                <span className="text-xs text-gray-400">6 أسئلة</span>
              </div>
            );
          })}
        </div>

        <button 
          onClick={startExam}
          className="bg-blue-600 hover:bg-blue-700 text-white text-2xl font-black py-5 px-16 rounded-full shadow-lg shadow-blue-200 transition-all hover:-translate-y-1 active:scale-95 flex items-center gap-4 mx-auto"
        >
          ابدأ الاختبار <ArrowRight className="bg-white/20 p-1 rounded-lg" />
        </button>
      </div>
      <p className="mt-8 text-gray-400 font-medium flex items-center gap-2">
        <Timer size={18} /> مدة الاختبار: 20 دقيقة
      </p>
    </div>
  );

  const Testing = () => {
    const ActiveSection = SECTIONS[currentSectionIdx];
    const SectionIcon = ActiveSection.icon;

    return (
      <div className="max-w-4xl mx-auto py-6 px-4">
        <div className="flex flex-wrap items-center justify-between gap-4 mb-8">
          <div className="flex items-center gap-3 bg-white px-6 py-3 rounded-2xl shadow-sm border border-gray-100">
            <div className={`p-2 rounded-xl ${ActiveSection.bg}`}>
              <SectionIcon className={ActiveSection.color} size={24} />
            </div>
            <div className="text-right">
              <div className="text-xs font-black uppercase text-gray-400 tracking-widest">{ActiveSection.label}</div>
              <div className="text-sm font-bold text-gray-700">السؤال {currentQuestionIdx + 1} من 6</div>
            </div>
          </div>

          <div className="flex items-center gap-4">
              <div className={`px-6 py-3 rounded-2xl font-black text-xl shadow-sm border ${timer < 300 ? 'bg-red-50 text-red-600 border-red-100 animate-pulse' : 'bg-white text-blue-600 border-gray-100'}`}>
                {formatTime(timer)}
              </div>
          </div>
        </div>

        <div className="w-full h-3 bg-gray-200 rounded-full mb-10 overflow-hidden flex">
          {SECTIONS.map((s, idx) => (
            <div 
              key={s.key} 
              className={`h-full transition-all duration-500 ${idx < currentSectionIdx ? 'bg-green-400' : idx === currentSectionIdx ? 'bg-blue-500' : 'bg-transparent'}`}
              style={{ width: '33.33%' }}
            />
          ))}
        </div>

        <div className="bg-white rounded-[2.5rem] shadow-xl p-10 border-b-8 border-gray-100 relative min-h-[450px] flex flex-col items-center justify-center">
          {currentSectionKey === 'listening' && (
            <button 
              onClick={() => playTTS(currentQuestion.audio)}
              className={`mb-10 p-12 rounded-full transition-all group ${isAudioPlaying ? 'bg-orange-100 scale-110' : 'bg-orange-50 hover:bg-orange-100 active:scale-95'}`}
            >
              <Volume2 size={54} className={`${isAudioPlaying ? 'text-orange-600 animate-bounce' : 'text-orange-400'}`} />
              <div className="absolute mt-14 left-1/2 -translate-x-1/2 text-orange-600 font-bold text-sm">اضغط للاستماع</div>
            </button>
          )}

          <h2 className="text-3xl font-black text-gray-800 text-center mb-12 leading-tight">
            {currentQuestion.text || (currentSectionKey === 'listening' ? 'استمع واختر الإجابة الصحيحة' : '')}
          </h2>

          <div className="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full">
            {currentQuestion.options.map(opt => (
              <button
                key={opt.id}
                onClick={() => handleAnswer(opt.id)}
                className={`
                  group relative p-8 rounded-3xl border-4 transition-all hover:-translate-y-2 active:scale-95 flex flex-col items-center justify-center
                  ${userAnswers[currentQuestion.id] === opt.id 
                    ? 'border-blue-500 bg-blue-50 shadow-blue-100' 
                    : 'border-gray-50 bg-gray-50 hover:border-blue-200 hover:bg-white shadow-sm'}
                `}
              >
                <span className={`text-6xl mb-4 transition-transform group-hover:scale-110 ${opt.size === 'small' ? 'text-4xl' : opt.size === 'large' ? 'text-8xl' : ''}`}>
                  {opt.val}
                </span>
                <span className="text-lg font-bold text-gray-600 uppercase tracking-wide">{opt.id}</span>
              </button>
            ))}
          </div>
        </div>
        
        <div className="mt-8 flex justify-between items-center px-4">
          <button 
            disabled={currentQuestionIdx === 0 && currentSectionIdx === 0}
            onClick={() => {
              if (currentQuestionIdx > 0) setCurrentQuestionIdx(currentQuestionIdx - 1);
              else if (currentSectionIdx > 0) {
                setCurrentSectionIdx(currentSectionIdx - 1);
                setCurrentQuestionIdx(5);
              }
            }}
            className="flex items-center gap-2 font-bold text-gray-400 hover:text-blue-500 disabled:opacity-0 transition-all"
          >
            <ArrowLeft size={20} /> السابق
          </button>
          <div className="text-gray-300 font-black italic">HIPPO PRE-A1</div>
        </div>
      </div>
    );
  };

  const Results = () => {
    const score = calculateScore();
    const total = 18;
    const percentage = Math.round((score / total) * 100);

    return (
      <div className="max-w-3xl mx-auto py-10 px-4">
        <div className="bg-white rounded-[3rem] shadow-2xl p-12 text-center border-b-8 border-green-200">
          <div className="relative inline-block mb-8">
            <Trophy className="w-32 h-32 text-yellow-400 mx-auto drop-shadow-lg" />
            <div className="absolute -top-2 -right-2 bg-pink-500 text-white rounded-full p-3 shadow-md animate-bounce">
              <Star fill="currentColor" size={24} />
            </div>
          </div>

          <h2 className="text-4xl font-black text-gray-800 mb-2">أحسنت يا بطل هيبو!</h2>
          <p className="text-gray-500 text-xl mb-10">لقد أتممت الاختبار بنجاح، نحن فخورون بك.</p>

          <div className="grid grid-cols-2 gap-6 mb-12">
            <div className="bg-blue-50 p-8 rounded-[2.5rem] border-2 border-white shadow-sm">
              <div className="text-5xl font-black text-blue-600 mb-2">{score}/{total}</div>
              <div className="text-sm font-bold text-blue-400 uppercase tracking-widest">النقاط</div>
            </div>
            <div className="bg-green-50 p-8 rounded-[2.5rem] border-2 border-white shadow-sm">
              <div className="text-5xl font-black text-green-600 mb-2">{percentage}%</div>
              <div className="text-sm font-bold text-green-400 uppercase tracking-widest">النسبة</div>
            </div>
          </div>

          <div className="flex flex-col sm:flex-row gap-4 justify-center">
            <button 
              onClick={() => setGameState('review')}
              className="bg-gray-100 hover:bg-gray-200 text-gray-700 font-black py-4 px-10 rounded-full transition-all flex items-center justify-center gap-3"
            >
              <Layout size={20} /> مراجعة الإجابات
            </button>
            <button 
              onClick={() => setGameState('lobby')}
              className="bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-10 rounded-full shadow-lg shadow-blue-100 transition-all flex items-center justify-center gap-3"
            >
              <RotateCcw size={20} /> محاولة جديدة
            </button>
          </div>
        </div>

        <div className="mt-8 bg-gradient-to-br from-indigo-600 to-blue-700 p-8 rounded-[2.5rem] text-white flex items-center justify-between shadow-xl">
            <div>
                <div className="flex items-center gap-2 mb-2">
                    <Award className="text-yellow-400" />
                    <span className="text-xs font-black uppercase tracking-widest opacity-80">سجل محاكاة رسمي</span>
                </div>
                <h3 className="text-2xl font-bold">Baby Hippo Certification</h3>
                <p className="text-sm opacity-70">إتقان المستوى Pre-A1</p>
            </div>
            <div className="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-md">
                <CheckCircle size={40} className="text-green-300" />
            </div>
        </div>
      </div>
    );
  };

  const Review = () => {
    const allQuestions = Object.values(EXAM_DATA).flat();
    return (
      <div className="max-w-4xl mx-auto py-10 px-4">
        <div className="flex items-center justify-between mb-8">
            <h2 className="text-3xl font-black text-gray-800">مراجعة الأسئلة</h2>
            <button onClick={() => setGameState('results')} className="text-blue-600 font-bold flex items-center gap-2 hover:underline">
                العودة للنتيجة <ArrowRight size={18} />
            </button>
        </div>
        <div className="space-y-6 text-right">
          {allQuestions.map((q, idx) => (
            <div key={q.id} className="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex items-start gap-6 flex-row-reverse">
              <div className={`w-12 h-12 rounded-2xl flex items-center justify-center font-black text-xl shrink-0 ${userAnswers[q.id] === q.correct ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600'}`}>
                {idx + 1}
              </div>
              <div className="flex-1">
                <p className="font-bold text-gray-700 mb-4">{q.text || q.audio}</p>
                <div className="flex flex-wrap gap-3 flex-row-reverse">
                  {q.options.map(opt => (
                    <div 
                      key={opt.id} 
                      className={`px-4 py-2 rounded-xl border-2 text-sm font-bold flex items-center gap-2
                        ${opt.id === q.correct ? 'border-green-500 bg-green-50 text-green-700' : 
                          userAnswers[q.id] === opt.id ? 'border-red-500 bg-red-50 text-red-700' : 'border-gray-100 text-gray-400'}
                      `}
                    >
                      {opt.val} {opt.id === q.correct && <CheckCircle size={14} />} {userAnswers[q.id] === opt.id && opt.id !== q.correct && <XCircle size={14} />}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-[#F8FAFC] font-sans selection:bg-blue-100">
      <div className="w-full">
        {gameState === 'lobby' && <Lobby />}
        {gameState === 'testing' && <Testing />}
        {gameState === 'results' && <Results />}
        {gameState === 'review' && <Review />}
      </div>
    </div>
  );
}
