import React, { useState, useEffect, useRef } from 'react';
import { 
  Trophy, Star, Volume2, ArrowRight, ArrowLeft, 
  RotateCcw, Award, CheckCircle, XCircle, 
  BookOpen, Languages, Headphones, Timer, 
  Check, X, Layout, GraduationCap, Play, Search
} from 'lucide-react';

// --- API Config for TTS ---
const apiKey = ""; 

// --- Data extracted from PDF Files ---
const EXAM_CONTENT = {
  reading: [
    // TASK 1: Tick or Cross (Based on Page 2 of Reading PDF)
    { id: 'r1', task: 1, type: 'tickcross', text: 'This is a train.', icon: '🚂', correct: true },
    { id: 'r2', task: 1, type: 'tickcross', text: 'This is a dragon.', icon: '🐲', correct: true },
    { id: 'r3', task: 1, type: 'tickcross', text: 'This is a crayon.', icon: '✏️', correct: true },
    { id: 'r4', task: 1, type: 'tickcross', text: 'This is a spoon.', icon: '🥄', correct: true },
    { id: 'r5', task: 1, type: 'tickcross', text: 'These are lemons.', icon: '🍋', correct: true },
    { id: 'r6', task: 1, type: 'tickcross', text: 'This is a guitar.', icon: '🎸', correct: true },
    
    // TASK 2: Choose correct word (Based on Page 3)
    { id: 'r7', task: 2, type: 'choice', text: 'This is a...', options: ['snake', 'spider', 'fish'], icon: '🐍', correct: 'snake' },
    { id: 'r8', task: 2, type: 'choice', text: 'This is a...', options: ['window', 'door', 'picture'], icon: '🪟', correct: 'window' },
    { id: 'r9', task: 2, type: 'choice', text: 'This is a...', options: ['pirate', 'princess', 'robot'], icon: '🏴‍☠️', correct: 'pirate' },
    { id: 'r10', task: 2, type: 'choice', text: 'This is a...', options: ['shirt', 'jumper', 'skirt'], icon: '👕', correct: 'shirt' },
    { id: 'r11', task: 2, type: 'choice', text: 'This is a...', options: ['sandwich', 'sausage', 'potato'], icon: '🥪', correct: 'sandwich' },
    { id: 'r12', task: 2, type: 'choice', text: 'These are...', options: ['pineapples', 'bananas', 'carrots'], icon: '🍍', correct: 'pineapples' },

    // TASK 4: Fill blanks from Bank (Based on Page 5 - Picnic Scene)
    { id: 'r13', task: 4, type: 'choice', text: 'The weather is...', options: ['sunny', 'clouds', 'red'], correct: 'sunny' },
    { id: 'r14', task: 4, type: 'choice', text: 'There are white...', options: ['clouds', 'picnic', 'playing'], correct: 'clouds' },
    { id: 'r15', task: 4, type: 'choice', text: 'The parents are...', options: ['sitting', 'playing', 'red'], correct: 'sitting' },
    { id: 'r16', task: 4, type: 'choice', text: 'The children are...', options: ['playing', 'sitting', 'clouds'], correct: 'playing' }
  ],
  useOfEnglish: [
    // Based on Use of English Sample 1 (Questions 51-70)
    { id: 51, text: 'It is ___ apple.', options: ['a', 'an', 'the'], correct: 'an' },
    { id: 52, text: '___ you happy?', options: ['Do', 'Is', 'Are'], correct: 'Are' },
    { id: 53, text: 'Abeer has lunch early ___ the afternoon.', options: ['in', 'on', 'at'], correct: 'in' },
    { id: 54, text: '___ someone in the classroom.', options: ["There isn't", "There is", "There are"], correct: 'There is' },
    { id: 55, text: 'My cousin has three ___ .', options: ['babies', 'baby', 'babys'], correct: 'babies' },
    { id: 56, text: '___ colour is your desk?', options: ['Whose', 'Which', 'What'], correct: 'What' },
    { id: 57, text: 'Chaaya really likes ___ with dolls.', options: ['playing', 'play', 'plays'], correct: 'playing' },
    { id: 58, text: 'My dad is ___ years old.', options: ['four', 'forty', 'fourty'], correct: 'forty' },
    { id: 59, text: 'She is doing her homework ___ .', options: ['this afternoon', 'now', 'on Sunday'], correct: 'now' },
    { id: 60, text: 'His shorts ___ yellow.', options: ['is', 'isn\'t', 'are'], correct: 'are' }
  ]
};

export default function App() {
  const [view, setView] = useState('welcome'); // welcome, test, results
  const [currentSection, setCurrentSection] = useState('reading');
  const [currentIdx, setCurrentIdx] = useState(0);
  const [answers, setAnswers] = useState({});
  const [timer, setTimer] = useState(1800); // 30 mins
  const [isAudioLoading, setIsAudioLoading] = useState(false);

  // Timer logic
  useEffect(() => {
    let interval;
    if (view === 'test' && timer > 0) {
      interval = setInterval(() => setTimer(prev => prev - 1), 1000);
    } else if (timer === 0) {
      setView('results');
    }
    return () => clearInterval(interval);
  }, [view, timer]);

  const questions = EXAM_CONTENT[currentSection];
  const q = questions[currentIdx];

  const handleAnswer = (val) => {
    setAnswers({ ...answers, [`${currentSection}_${q.id}`]: val });
    
    if (currentIdx < questions.length - 1) {
      setTimeout(() => setCurrentIdx(currentIdx + 1), 300);
    } else if (currentSection === 'reading') {
      setCurrentSection('useOfEnglish');
      setCurrentIdx(0);
      setTimer(1200); // Reset to 20 mins for Use of English
    } else {
      setView('results');
    }
  };

  const calculateScore = () => {
    let score = 0;
    Object.keys(EXAM_CONTENT).forEach(sec => {
      EXAM_CONTENT[sec].forEach(quest => {
        if (answers[`${sec}_${quest.id}`] === quest.correct) score++;
      });
    });
    return score;
  };

  const playTTS = async (text) => {
    if (isAudioLoading) return;
    setIsAudioLoading(true);
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: `Slowly and clearly: ${text}` }] }],
          generationConfig: {
            responseModalities: ["AUDIO"],
            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Puck" } } }
          },
          model: "gemini-2.5-flash-preview-tts"
        })
      });
      const data = await response.json();
      const audioBase64 = data.candidates[0].content.parts[0].inlineData.data;
      const audioBlob = new Blob([Uint8Array.from(atob(audioBase64), c => c.charCodeAt(0))], { type: 'audio/mp3' });
      const audioUrl = URL.createObjectURL(audioBlob);
      new Audio(audioUrl).play();
    } catch (e) {
      console.error(e);
    } finally {
      setIsAudioLoading(false);
    }
  };

  if (view === 'welcome') {
    return (
      <div className="min-h-screen bg-blue-50 flex flex-col items-center justify-center p-6 text-center" dir="rtl">
        <div className="bg-white p-10 rounded-[3rem] shadow-2xl max-w-2xl border-b-8 border-blue-200">
          <GraduationCap className="w-24 h-24 text-blue-500 mx-auto mb-6" />
          <h1 className="text-4xl font-black text-gray-800 mb-4 tracking-tight">محاكاة اختبار هيبو الرسمي</h1>
          <p className="text-xl text-gray-500 mb-8 leading-relaxed">
            تم إعداد هذا الاختبار بناءً على نماذج الوزارة لعامي 2019 و2020. 
            يتضمن قسم القراءة وقسم استخدام اللغة الإنجليزية.
          </p>
          <div className="flex gap-4 justify-center mb-10">
            <div className="bg-blue-50 p-4 rounded-2xl border border-blue-100 flex flex-col items-center">
              <BookOpen className="text-blue-500 mb-2" />
              <span className="text-sm font-bold">القراءة (30 د)</span>
            </div>
            <div className="bg-pink-50 p-4 rounded-2xl border border-pink-100 flex flex-col items-center">
              <Languages className="text-pink-500 mb-2" />
              <span className="text-sm font-bold">اللغة (20 د)</span>
            </div>
          </div>
          <button 
            onClick={() => setView('test')}
            className="bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-12 rounded-full text-2xl transition-all hover:scale-105 active:scale-95 shadow-lg shadow-blue-200"
          >
            ابدأ الاختبار الفعلي
          </button>
        </div>
      </div>
    );
  }

  if (view === 'results') {
    const finalScore = calculateScore();
    const total = EXAM_CONTENT.reading.length + EXAM_CONTENT.useOfEnglish.length;
    return (
      <div className="min-h-screen bg-blue-50 flex flex-col items-center justify-center p-6 text-center" dir="rtl">
        <div className="bg-white p-12 rounded-[3.5rem] shadow-2xl max-w-2xl w-full border-b-8 border-green-200">
          <Trophy className="w-32 h-32 text-yellow-400 mx-auto mb-8" />
          <h2 className="text-4xl font-black text-gray-800 mb-2">أحسنت يا بطل!</h2>
          <p className="text-xl text-gray-400 mb-10">لقد أكملت جميع مهام Baby Hippo بنجاح.</p>
          
          <div className="grid grid-cols-2 gap-6 mb-12">
            <div className="bg-blue-50 p-6 rounded-3xl border-2 border-white shadow-sm">
              <div className="text-5xl font-black text-blue-600 mb-2">{finalScore} / {total}</div>
              <div className="text-sm font-bold text-blue-300 uppercase tracking-widest">إجمالي النقاط</div>
            </div>
            <div className="bg-green-50 p-6 rounded-3xl border-2 border-white shadow-sm">
              <div className="text-5xl font-black text-green-600 mb-2">{Math.round((finalScore/total)*100)}%</div>
              <div className="text-sm font-bold text-green-300 uppercase tracking-widest">النسبة المئوية</div>
            </div>
          </div>

          <button 
            onClick={() => window.location.reload()}
            className="bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-10 rounded-full flex items-center justify-center gap-3 mx-auto transition-all"
          >
            <RotateCcw size={20} /> إعادة الاختبار
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#F8FAFC] p-4 font-sans text-gray-800">
      <div className="max-w-4xl mx-auto">
        
        {/* Header */}
        <div className="flex items-center justify-between mb-8 bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
          <div className="flex items-center gap-4">
            <div className={`p-3 rounded-xl ${currentSection === 'reading' ? 'bg-blue-50 text-blue-600' : 'bg-pink-50 text-pink-600'}`}>
              {currentSection === 'reading' ? <BookOpen /> : <Languages />}
            </div>
            <div className="text-right">
              <h4 className="text-xs font-black text-gray-400 uppercase tracking-widest">
                {currentSection === 'reading' ? 'Reading Task ' + q.task : 'Use of English'}
              </h4>
              <p className="text-lg font-bold">السؤال {currentIdx + 1} من {questions.length}</p>
            </div>
          </div>
          <div className={`px-6 py-3 rounded-xl font-black text-2xl border ${timer < 300 ? 'bg-red-50 text-red-600 border-red-100 animate-pulse' : 'bg-blue-50 text-blue-600 border-blue-50'}`}>
            {Math.floor(timer / 60)}:{(timer % 60).toString().padStart(2, '0')}
          </div>
        </div>

        {/* Progress Bar */}
        <div className="w-full h-3 bg-gray-200 rounded-full mb-10 overflow-hidden">
          <div 
            className={`h-full transition-all duration-500 ${currentSection === 'reading' ? 'bg-blue-500' : 'bg-pink-500'}`}
            style={{ width: `${((currentIdx + 1) / questions.length) * 100}%` }}
          />
        </div>

        {/* Question Area */}
        <div className="bg-white rounded-[3rem] shadow-xl p-10 min-h-[500px] flex flex-col items-center justify-center border-b-8 border-gray-100 relative">
          
          {/* Audio Helper */}
          <button 
            onClick={() => playTTS(q.text)}
            className="absolute top-8 right-8 p-4 bg-gray-50 rounded-full text-gray-400 hover:bg-blue-50 hover:text-blue-500 transition-all"
          >
            <Volume2 size={24} className={isAudioLoading ? 'animate-pulse' : ''} />
          </button>

          {/* Icon/Image Placeholder */}
          {q.icon && (
            <div className="w-48 h-48 bg-gray-50 rounded-[2.5rem] flex items-center justify-center text-8xl mb-10 shadow-inner">
              {q.icon}
            </div>
          )}

          <h2 className="text-4xl font-black text-gray-800 text-center mb-12 leading-snug">
            {q.text}
          </h2>

          {/* Inputs based on type */}
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-lg">
            {q.type === 'tickcross' && (
              <>
                <button 
                  onClick={() => handleAnswer(true)}
                  className={`p-6 rounded-3xl border-4 flex items-center justify-center gap-4 text-2xl font-black transition-all hover:-translate-y-1 ${answers[`${currentSection}_${q.id}`] === true ? 'bg-green-50 border-green-500 text-green-700' : 'bg-gray-50 border-gray-100'}`}
                >
                  <Check className="w-10 h-10" /> صح
                </button>
                <button 
                  onClick={() => handleAnswer(false)}
                  className={`p-6 rounded-3xl border-4 flex items-center justify-center gap-4 text-2xl font-black transition-all hover:-translate-y-1 ${answers[`${currentSection}_${q.id}`] === false ? 'bg-red-50 border-red-500 text-red-700' : 'bg-gray-50 border-gray-100'}`}
                >
                  <X className="w-10 h-10" /> خطأ
                </button>
              </>
            )}

            {q.type === 'choice' || currentSection === 'useOfEnglish' ? (
              <div className="grid grid-cols-1 gap-3 w-full sm:col-span-2">
                {q.options.map(opt => (
                  <button
                    key={opt}
                    onClick={() => handleAnswer(opt)}
                    className={`p-5 rounded-2xl border-2 text-xl font-bold transition-all text-left px-8 ${answers[`${currentSection}_${q.id}`] === opt ? 'bg-blue-50 border-blue-500 text-blue-700' : 'bg-gray-50 border-gray-200 hover:border-blue-200'}`}
                  >
                    {opt}
                  </button>
                ))}
              </div>
            ) : null}
          </div>
        </div>

        {/* Footer Navigation */}
        <div className="mt-8 flex justify-between items-center px-4" dir="rtl">
           <button 
             onClick={() => currentIdx > 0 && setCurrentIdx(currentIdx - 1)}
             className={`flex items-center gap-2 font-bold text-gray-400 hover:text-blue-600 transition-all ${currentIdx === 0 ? 'opacity-0' : ''}`}
           >
             <ArrowRight size={20} /> السابق
           </button>
           <div className="text-gray-300 font-black italic tracking-widest">BABY HIPPO 2026</div>
        </div>
      </div>
    </div>
  );
}
