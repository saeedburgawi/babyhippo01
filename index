<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hippo Simulation - Baby Hippo</title>
    <script src="[https://cdn.tailwindcss.com](https://cdn.tailwindcss.com)"></script>
    <link href="[https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&family=Fredoka+One&display=swap](https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&family=Fredoka+One&display=swap)" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #f0f9ff; }
       .baby-font { font-family: 'Fredoka One', cursive; }
       .task-card { display: none; }
       .task-card.active { display: block; animation: fadeIn 0.5s; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
       .btn-option { transition: all 0.2s; border-width: 4px; }
       .btn-option:active { transform: scale(0.95); }
       .mascot-bubble { position: relative; background: #fff; border-radius: 20px; padding: 15px; border: 3px solid #0ea5e9; }
       .mascot-bubble::after { content: ''; position: absolute; right: -20px; top: 20px; border-width: 10px; border-style: solid; border-color: transparent transparent transparent #0ea5e9; }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-4xl mx-auto flex justify-between items-center mb-6 bg-white p-4 rounded-3xl shadow-sm border-b-4 border-sky-200">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-sky-400 rounded-full flex items-center justify-center text-white text-2xl shadow-inner">🦛</div>
            <div>
                <h1 class="text-xl font-bold text-sky-800">Hippo 2026 Simulation</h1>
                <p class="text-sm text-sky-500 font-bold">Level: Baby Hippo (Pre-A1)</p>
            </div>
        </div>
        <div class="text-right">
            <div id="timer" class="text-2xl font-bold text-orange-500 baby-font">40:00</div>
            <div class="w-32 h-3 bg-gray-200 rounded-full mt-2">
                <div id="progress" class="h-full bg-green-400 rounded-full" style="width: 20%"></div>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border-4 border-sky-100 min-h-[500px] relative">
        
        <div class="flex items-start p-6 gap-4 bg-sky-50">
            <div class="w-20 shrink-0 text-5xl">🚀</div>
            <div class="mascot-bubble shadow-sm flex-1">
                <p id="instruction-text" class="text-lg text-sky-900 font-bold">Look at the picture. Is it correct? ✅ or ❌</p>
                <button onclick="playInstruction()" class="mt-2 text-sky-600 flex items-center gap-2 hover:underline">
                    <span>🔊 Listen</span>
                </button>
            </div>
        </div>

        <div id="quiz-container" class="p-6 md:p-10">
            
            <div id="task1" class="task-card active text-center">
                <div class="mb-6 inline-block p-4 bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200">
                    <img src="[https://img.icons8.com/clouds/200/t-shirt.png](https://img.icons8.com/clouds/200/t-shirt.png)" alt="T-shirt" class="mx-auto w-48">
                    <p class="text-2xl font-bold mt-4 baby-font text-gray-700">"This is a t-shirt."</p>
                </div>
                <div class="flex justify-center gap-8">
                    <button onclick="nextTask(2)" class="btn-option w-24 h-24 bg-green-100 border-green-500 rounded-2xl text-4xl shadow-lg hover:bg-green-200">✅</button>
                    <button onclick="nextTask(2)" class="btn-option w-24 h-24 bg-red-100 border-red-500 rounded-2xl text-4xl shadow-lg hover:bg-red-200">❌</button>
                </div>
            </div>

            <div id="task2" class="task-card text-center">
                <div class="mb-6 inline-block p-4 bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200">
                    <img src="[https://img.icons8.com/clouds/200/lion.png](https://img.icons8.com/clouds/200/lion.png)" alt="Lion" class="mx-auto w-48">
                    <p class="text-2xl font-bold mt-4 baby-font text-gray-700">This is a _________.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <button onclick="nextTask(3)" class="btn-option p-6 bg-white border-sky-400 rounded-2xl text-xl font-bold text-sky-700 hover:bg-sky-50">Tiger</button>
                    <button onclick="nextTask(3)" class="btn-option p-6 bg-white border-sky-400 rounded-2xl text-xl font-bold text-sky-700 hover:bg-sky-50">Lion</button>
                    <button onclick="nextTask(3)" class="btn-option p-6 bg-white border-sky-400 rounded-2xl text-xl font-bold text-sky-700 hover:bg-sky-50">Elephant</button>
                </div>
            </div>

            <div id="task3" class="task-card">
                <div class="flex flex-col md:flex-row gap-8">
                    <div class="flex-1 bg-yellow-50 p-4 rounded-2xl border-2 border-yellow-200">
                        <img src="[https://img.icons8.com/clouds/500/playground.png](https://img.icons8.com/clouds/500/playground.png)" alt="Scene" class="w-full">
                    </div>
                    <div class="flex-1 space-y-6">
                        <p class="text-xl font-bold text-gray-700">1. The children are ________.</p>
                        <div class="space-y-3">
                            <label class="flex items-center gap-4 p-4 border-2 rounded-xl cursor-pointer hover:bg-gray-50">
                                <input type="radio" name="q3" class="w-6 h-6"> <span class="text-lg font-bold">Walking</span>
                            </label>
                            <label class="flex items-center gap-4 p-4 border-2 rounded-xl cursor-pointer hover:bg-gray-50">
                                <input type="radio" name="q3" class="w-6 h-6"> <span class="text-lg font-bold">Running</span>
                            </label>
                            <label class="flex items-center gap-4 p-4 border-2 rounded-xl cursor-pointer hover:bg-gray-50">
                                <input type="radio" name="q3" class="w-6 h-6"> <span class="text-lg font-bold">Sleeping</span>
                            </label>
                        </div>
                        <button onclick="nextTask(4)" class="w-full py-4 bg-orange-400 text-white rounded-2xl font-bold text-xl shadow-lg">Next ➡️</button>
                    </div>
                </div>
            </div>

            <div id="task4" class="task-card">
                <div class="bg-blue-50 p-6 rounded-2xl mb-6">
                    <div class="flex flex-wrap gap-3 mb-6">
                        <span class="bg-white px-4 py-2 rounded-lg border-2 border-blue-400 font-bold text-blue-600 shadow-sm cursor-move">Sunny</span>
                        <span class="bg-white px-4 py-2 rounded-lg border-2 border-blue-400 font-bold text-blue-600 shadow-sm cursor-move">Picnic</span>
                        <span class="bg-white px-4 py-2 rounded-lg border-2 border-blue-400 font-bold text-blue-600 shadow-sm cursor-move">Red</span>
                    </div>
                    <div class="text-xl leading-relaxed text-gray-800 space-y-4 font-medium">
                        <p>There are four people in the picture. They are having a <span class="inline-block w-24 border-b-4 border-blue-400 bg-white/50 h-8"></span>.</p>
                        <p>The weather is <span class="inline-block w-24 border-b-4 border-blue-400 bg-white/50 h-8"></span>. The girl is wearing a <span class="inline-block w-24 border-b-4 border-blue-400 bg-white/50 h-8"></span> dress.</p>
                    </div>
                </div>
                <button onclick="nextTask(5)" class="w-full py-4 bg-green-500 text-white rounded-2xl font-bold text-xl shadow-lg">Finish Task ➡️</button>
            </div>

            <div id="task5" class="task-card text-center">
                <div class="mb-6">
                    <img src="[https://img.icons8.com/clouds/300/classroom.png](https://img.icons8.com/clouds/300/classroom.png)" alt="Classroom" class="mx-auto w-64">
                </div>
                <div class="max-w-md mx-auto space-y-6">
                    <div class="text-left">
                        <p class="text-lg font-bold text-gray-700 mb-2">Q: How many children are there?</p>
                        <input type="text" placeholder="Type your answer here..." class="w-full p-4 border-4 border-sky-200 rounded-2xl text-center text-xl font-bold outline-none focus:border-sky-400">
                    </div>
                    <button onclick="showResults()" class="w-full py-6 bg-sky-600 text-white rounded-2xl font-bold text-2xl shadow-xl hover:bg-sky-700">SUBMIT TEST 🏆</button>
                </div>
            </div>

            <div id="results" class="task-card text-center py-10">
                <div class="text-8xl mb-6">🎖️</div>
                <h2 class="text-4xl font-bold text-sky-900 mb-2">Well Done!</h2>
                <p class="text-xl text-gray-600 mb-8">You finished the simulation.</p>
                <div class="flex justify-center gap-2 mb-10">
                    <span class="text-5xl">🛡️</span><span class="text-5xl">🛡️</span><span class="text-5xl">🛡️</span><span class="text-5xl">🛡️</span><span class="text-5xl">🛡️</span>
                </div>
                <button onclick="location.reload()" class="px-10 py-4 bg-gray-100 text-gray-600 rounded-2xl font-bold hover:bg-gray-200">Try Again</button>
            </div>

        </div>
    </div>

    <script>
        function nextTask(taskNum) {
            document.querySelectorAll('.task-card').forEach(c => c.classList.remove('active'));
            document.getElementById('task' + taskNum).classList.add('active');
            
            let progress = (taskNum / 5) * 100;
            document.getElementById('progress').style.width = progress + '%';

            let instruction = "";
            switch(taskNum) {
                case 2: instruction = "Choose the correct word for the picture. 🦁"; break;
                case 3: instruction = "Look at the scene. What are they doing? 🎡"; break;
                case 4: instruction = "Complete the story using the words above. ✍️"; break;
                case 5: instruction = "Look at the picture and answer the question. 🏫"; break;
            }
            if(instruction) document.getElementById('instruction-text').innerText = instruction;
        }

        function showResults() {
            document.querySelectorAll('.task-card').forEach(c => c.classList.remove('active'));
            document.getElementById('results').classList.add('active');
            document.getElementById('instruction-text').innerText = "Congratulations! You completed the test. 🎉";
        }

        function playInstruction() {
            // Simulation of text-to-speech or audio play
            alert("Playing Audio: " + document.getElementById('instruction-text').innerText);
        }

        // Simple Timer
        let time = 2400; // 40 minutes in seconds
        setInterval(() => {
            if(time > 0) {
                time--;
                let min = Math.floor(time / 60);
                let sec = time % 60;
                document.getElementById('timer').innerText = `${min}:${sec < 10? '0' + sec : sec}`;
            }
        }, 1000);
    </script>
</body>
</html>
